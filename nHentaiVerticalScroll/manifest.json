{
  "manifest_version": 3,
  "name": "nHentai Vertical Scroll",
  "version": "1.2.4",
  "description": "Loads all images onto a single page for vertical scrolling.",
  "icons": {
    "48": "icons/icon_48.png",
    "96": "icons/icon_96.png",
    "128": "icons/icon_128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "nhentaiverticalscroll@coomerland.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      },
    "gecko_android": {
      "strict_min_version": "142.0"
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["https://nhentai.net/g/*"],
      "js": ["js/vertical_scroll.js"]
    }
  ],
  "host_permissions": [
    "https://i.nhentai.net/*",
    "https://nhentai.net/*"
  ]
}
